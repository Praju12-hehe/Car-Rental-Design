{
  "buildCommand": "pnpm install && pnpm run build",
  "installCommand": "pnpm install",
  "outputDirectory": "artifacts/varda/dist/public",
  "build": {
    "env": {
      "PORT": "5173",
      "BASE_PATH": "/"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
